# n8n webhook endpoint for chat messages
VITE_N8N_WEBHOOK=https://your-n8n-instance.app.n8n.cloud/webhook/your-webhook-id/chat

# URL of the logo displayed in the header
VITE_LOGO_URL=https://your-cdn.example.com/logo.png

# Vercel / storage (filled by vercel env pull)
BLOB_READ_WRITE_TOKEN=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
OPENAI_API_KEY=
